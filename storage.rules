// storage.rules
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile photos — owner can upload, anyone logged in can read
    match /users/{userId}/avatar.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024   // 2 MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Event cover images — organizer can upload to their own events
    match /events/{eventId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024   // 5 MB max
        && request.resource.contentType.matches('image/.*');
    }
  }
}
