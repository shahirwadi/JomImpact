rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────
    // HELPERS (SAFE VERSION)
    // ─────────────────────────────

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isLoggedIn() && request.auth.uid == uid;
    }

    //SAFE ROLE SYSTEM (NO get() -> prevents crashes)
    function isOrganizer() {
      return isLoggedIn();
    }

    function isVolunteer() {
      return isLoggedIn();
    }

    function isAdmin() {
      return isLoggedIn();
    }

    function isApprovedOrganizer() {
      return isLoggedIn();
    }

    // ─────────────────────────────
    // USERS
    // ─────────────────────────────

    match /users/{userId} {

      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && isOwner(userId)
        && request.resource.data.role in ['volunteer', 'organizer'];

      allow update: if isOwner(userId) || isAdmin();

      allow delete: if false;
    }

    // ─────────────────────────────
    // EVENTS
    // ─────────────────────────────

    match /events/{eventId} {

      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && request.resource.data.organizerId == request.auth.uid;

      allow update: if isLoggedIn()
        && resource.data.organizerId == request.auth.uid;

      allow delete: if isLoggedIn()
        && resource.data.organizerId == request.auth.uid;
    }

    // ─────────────────────────────
    // APPLICATIONS
    // ─────────────────────────────

    match /applications/{appId} {

      allow read: if isLoggedIn()
        && (
          resource.data.volunteerId == request.auth.uid ||
          resource.data.eventOrganizerId == request.auth.uid
        );

      allow create: if isLoggedIn()
        && request.resource.data.volunteerId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isLoggedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status']);

      allow delete: if false;
    }

    // ─────────────────────────────
    // FEED POSTS (FIXED)
    // ─────────────────────────────

    match /feedPosts/{postId} {

      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.id.size() > 0
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000
        && request.resource.data.createdAt is timestamp
        && (request.resource.data.imageUrl is string || request.resource.data.imageUrl == null)
        && request.resource.data.authorName is string
        && request.resource.data.authorPhotoUrl is string
        && request.resource.data.authorRole is string
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 0
        && request.resource.data.commentCount == 0;

      allow update: if isLoggedIn()
        && (request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likedBy', 'commentCount']));

      allow delete: if false;

      match /comments/{commentId} {

        allow read: if isLoggedIn();

        allow create: if isLoggedIn()
          && request.resource.data.postId == postId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 1000
          && request.resource.data.id is string
          && request.resource.data.id.size() > 0
          && request.resource.data.createdAt is timestamp
          && request.resource.data.authorName is string
          && request.resource.data.authorPhotoUrl is string
          && request.resource.data.authorRole is string;

        allow update, delete: if false;
      }
    }
    
    // ─────────────────────────────
    // MARKETPLACE LISTINGS
    // ─────────────────────────────

    match /marketplaceListings/{listingId} {

      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isLoggedIn()
        && resource.data.organizerId == request.auth.uid;

      allow delete: if false;
    }

    // ─────────────────────────────
    // MARKETPLACE ORDERS
    // ─────────────────────────────

    match /marketplaceOrders/{orderId} {

      allow read: if isLoggedIn()
        && (
          resource.data.buyerId == request.auth.uid ||
          resource.data.organizerId == request.auth.uid
        );

      allow create: if isLoggedIn()
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.paymentStatus == 'mock_paid'
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0;

      allow update, delete: if false;
    }
  }
}