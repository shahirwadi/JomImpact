// firestore.rules
//
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isOrganizer() {
      return isLoggedIn() && getUserRole() == 'organizer';
    }

    function isVolunteer() {
      return isLoggedIn() && getUserRole() == 'volunteer';
    }

    function isAdmin() {
      return isLoggedIn() && getUserRole() == 'admin';
    }

    function isApprovedOrganizer() {
      return isOrganizer() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizerApprovalStatus == 'approved';
    }

    function isFeedRole(role) {
      return role in ['organizer', 'volunteer'];
    }

    function isMarketplaceStatus(status) {
      return status in ['pending', 'approved', 'rejected'];
    }

    function isMarketplaceOrderStatus(status) {
      return status in ['confirmed', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function hasOptionalString(data, field) {
      return data.get(field, null) == null || data.get(field, null) is string;
    }

    function isMalaysiaState(state) {
      return state in [
        'Johor', 'Kedah', 'Kelantan', 'Melaka', 'Negeri Sembilan',
        'Pahang', 'Penang', 'Perak', 'Perlis', 'Sabah', 'Sarawak',
        'Selangor', 'Terengganu', 'Kuala Lumpur', 'Labuan', 'Putrajaya'
      ];
    }

    // ── Users collection ─────────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone logged in can read any user profile (for organizer browse)
      allow read: if isLoggedIn();

      // Users can only create volunteer or organizer accounts for themselves.
      allow create: if isLoggedIn()
        && isOwner(userId)
        && request.resource.data.id == request.auth.uid
        && request.resource.data.role in ['volunteer', 'organizer']
        && request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && isMalaysiaState(request.resource.data.state)
        && (
          (request.resource.data.role == 'volunteer'
            && request.resource.data.organizerApprovalStatus == 'notRequired')
          ||
          (request.resource.data.role == 'organizer'
            && request.resource.data.organizerApprovalStatus == 'pending')
        );

      // Users may edit their own profile details, but cannot promote themselves
      // or change their organizer approval state. Admins can review and update.
      allow update: if (
        isLoggedIn()
        && isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.organizerApprovalStatus == resource.data.organizerApprovalStatus
        && request.resource.data.approvalNotes == resource.data.approvalNotes
        && request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && isMalaysiaState(request.resource.data.state)
      ) || isAdmin();

      // Prevent deletion (soft-delete only)
      allow delete: if false;
    }

    // ── Events collection ────────────────────────────────────────────────────
    match /events/{eventId} {
      // Published events can be read by anyone logged in
      allow read: if isLoggedIn();

      // Only organizers can create events
      allow create: if isApprovedOrganizer()
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.location is string
        && request.resource.data.location.size() > 0
        && isMalaysiaState(request.resource.data.state);

      // Only the event's own organizer can update/delete
      allow update: if isApprovedOrganizer()
        && resource.data.organizerId == request.auth.uid
        && (
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['location', 'state']) ||
          (
            request.resource.data.location is string
            && request.resource.data.location.size() > 0
            && isMalaysiaState(request.resource.data.state)
          )
        );

      allow delete: if isApprovedOrganizer()
        && resource.data.organizerId == request.auth.uid;
    }

    // ── Applications collection ───────────────────────────────────────────────
    match /applications/{appId} {
      // Volunteer can read their own applications
      // Organizer can read applications for their events
      allow read: if isLoggedIn() && (
        resource.data.volunteerId == request.auth.uid ||
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
      );

      // Only volunteers can create applications
      allow create: if isVolunteer()
        && request.resource.data.volunteerId == request.auth.uid
        && request.resource.data.status == 'pending';

      // Organizers manage the review pipeline; volunteers may only withdraw.
      allow update: if (
        isApprovedOrganizer()
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status in ['published', 'ongoing']
        && resource.data.status != 'withdrawn'
        && request.resource.data.status in ['pending', 'reviewing', 'accepted', 'waitlisted', 'rejected']
        && request.resource.data.reviewedBy == request.auth.uid
        && request.resource.data.reviewedAt is string
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'reviewedBy', 'reviewedAt'])
      ) || (
        isVolunteer()
        && resource.data.volunteerId == request.auth.uid
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status in ['published', 'ongoing']
        && request.resource.data.status == 'withdrawn'
        && request.resource.data.withdrawnAt is string
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'withdrawnAt'])
      ) || (
        isApprovedOrganizer()
        && resource.data.status == 'accepted'
        && request.resource.data.status == 'accepted'
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'completed'
        && request.resource.data.attendanceStatus in ['attended', 'partial', 'noShow', 'excused']
        && request.resource.data.verifiedHours is int
        && request.resource.data.verifiedHours >= 0
        && (
          (request.resource.data.attendanceStatus in ['attended', 'partial']
            && request.resource.data.verifiedHours > 0) ||
          (request.resource.data.attendanceStatus in ['noShow', 'excused']
            && request.resource.data.verifiedHours == 0)
        )
        && request.resource.data.attendanceReviewedBy == request.auth.uid
        && request.resource.data.attendanceReviewedAt is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendanceStatus',
          'verifiedHours',
          'attendanceReviewedBy',
          'attendanceReviewedAt'
        ])
      ) || (
        isApprovedOrganizer()
        && resource.data.status == 'accepted'
        && request.resource.data.status == 'accepted'
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.status == 'completed'
        && request.resource.data.impactPoints == resource.data.verifiedHours * 10
        && request.resource.data.pointsAwardedAt is string
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['impactPoints', 'pointsAwardedAt'])
      );

      // No deletion
      allow delete: if false;
    }

    // Public social feed for organizers and volunteers.
    match /feedPosts/{postId} {
      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'authorId',
          'authorName',
          'authorPhotoUrl',
          'authorRole',
          'content',
          'imageUrl',
          'likedBy',
          'commentCount',
          'createdAt'
        ])
        && request.resource.data.id == postId
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() > 0
        && hasOptionalString(request.resource.data, 'authorPhotoUrl')
        && isFeedRole(request.resource.data.authorRole)
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 2000
        && (
          request.resource.data.content.size() > 0 ||
          (
            request.resource.data.keys().hasAny(['imageUrl']) &&
            request.resource.data.imageUrl is string &&
            request.resource.data.imageUrl.size() > 0
          )
        )
        && request.resource.data.likedBy is list
        && request.resource.data.likedBy.size() == 0
        && request.resource.data.commentCount == 0
        && request.resource.data.createdAt is string;

      allow update: if isLoggedIn() && (
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['commentCount'])
          && request.resource.data.commentCount is int
          && request.resource.data.commentCount
            == resource.data.get('commentCount', 0) + 1
        ) || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy'])
          && request.resource.data.likedBy is list
        ) || (
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['content', 'imageUrl', 'updatedAt'])
          && request.resource.data.content is string
          && request.resource.data.content.size() <= 2000
          && hasOptionalString(request.resource.data, 'imageUrl')
          && (
            request.resource.data.content.size() > 0 ||
            (
              request.resource.data.get('imageUrl', null) is string
              && request.resource.data.imageUrl.size() > 0
            )
          )
          && request.resource.data.updatedAt is string
        )
      );

      allow delete: if isLoggedIn()
        && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isLoggedIn();

        allow create: if isLoggedIn()
          && request.resource.data.id == commentId
          && request.resource.data.postId == postId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 1000;

        allow update, delete: if false;
      }
    }

    // Marketplace listings submitted by organizers and reviewed by admins.
    match /marketplaceItems/{itemId} {
      allow read: if isLoggedIn() && (
        isAdmin() ||
        resource.data.status == 'approved' ||
        resource.data.organizerId == request.auth.uid
      );

      allow create: if isApprovedOrganizer()
        && request.resource.data.keys().hasOnly([
          'id',
          'organizerId',
          'organizerName',
          'title',
          'description',
          'price',
          'quantity',
          'imageUrl',
          'isAvailable',
          'status',
          'adminNotes',
          'reviewedBy',
          'reviewedAt',
          'createdAt'
        ])
        && request.resource.data.id == itemId
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.organizerName is string
        && request.resource.data.organizerName.size() > 0
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 2000
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.quantity is int
        && request.resource.data.quantity > 0
        && hasOptionalString(request.resource.data, 'imageUrl')
        && request.resource.data.isAvailable == true
        && request.resource.data.status == 'pending'
        && request.resource.data.adminNotes == null
        && request.resource.data.reviewedBy == null
        && request.resource.data.reviewedAt == null
        && request.resource.data.createdAt is string;

      allow update: if (
        isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'adminNotes', 'reviewedBy', 'reviewedAt'])
          && isMarketplaceStatus(request.resource.data.status)
          && hasOptionalString(request.resource.data, 'adminNotes')
          && request.resource.data.reviewedBy == request.auth.uid
          && request.resource.data.reviewedAt is string
      ) || (
        isApprovedOrganizer()
          && resource.data.organizerId == request.auth.uid
          && resource.data.status == 'approved'
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isAvailable'])
          && request.resource.data.isAvailable is bool
      ) || (
        isVolunteer()
          && resource.data.status == 'approved'
          && resource.data.get('isAvailable', true) == true
          && resource.data.get('quantity', 1) > 0
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['quantity', 'isAvailable'])
          && request.resource.data.quantity
            == resource.data.get('quantity', 1) - 1
          && request.resource.data.isAvailable
            == (request.resource.data.quantity > 0)
      );

      allow delete: if isApprovedOrganizer()
        && resource.data.organizerId == request.auth.uid;
    }

    // Organizer-only notes live separately because rules cannot hide fields.
    match /applicationReviews/{appId} {
      allow read: if isApprovedOrganizer()
        && get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid;

      allow create, update: if isApprovedOrganizer()
        && request.resource.data.applicationId == appId
        && request.resource.data.reviewedBy == request.auth.uid
        && request.resource.data.reviewedAt is string
        && hasOptionalString(request.resource.data, 'reviewNotes')
        && get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizerId == request.auth.uid;

      allow delete: if false;
    }

    match /impactAwards/{awardId} {
      allow read: if isLoggedIn() && (
        resource.data.volunteerId == request.auth.uid ||
        get(/databases/$(database)/documents/events/$(resource.data.eventId)).data.organizerId == request.auth.uid
      );

      allow create: if isApprovedOrganizer()
        && request.resource.data.awardedBy == request.auth.uid
        && request.resource.data.points is int
        && request.resource.data.hours is int
        && request.resource.data.points == request.resource.data.hours * 10
        && request.resource.data.points > 0
        && request.resource.data.awardedAt is string
        && get(/databases/$(database)/documents/events/$(request.resource.data.eventId)).data.organizerId == request.auth.uid
        && get(/databases/$(database)/documents/applications/$(request.resource.data.applicationId)).data.volunteerId == request.resource.data.volunteerId
        && get(/databases/$(database)/documents/applications/$(request.resource.data.applicationId)).data.status == 'accepted'
        && get(/databases/$(database)/documents/applications/$(request.resource.data.applicationId)).data.attendanceStatus in ['attended', 'partial']
        && get(/databases/$(database)/documents/applications/$(request.resource.data.applicationId)).data.verifiedHours == request.resource.data.hours;

      allow update, delete: if false;
    }

    // Purchase records created by volunteers when buying approved listings.
    match /marketplacePurchases/{purchaseId} {
      allow read: if isLoggedIn() && (
        isAdmin() ||
        resource.data.buyerId == request.auth.uid ||
        resource.data.organizerId == request.auth.uid
      );

      allow create: if isVolunteer()
        && request.resource.data.keys().hasOnly([
          'id',
          'itemId',
          'itemTitle',
          'organizerId',
          'buyerId',
          'buyerName',
          'buyerEmail',
          'recipientName',
          'phone',
          'addressLine1',
          'addressLine2',
          'city',
          'state',
          'postcode',
          'country',
          'deliveryInstructions',
          'price',
          'status',
          'paymentStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == purchaseId
        && request.resource.data.buyerId == request.auth.uid
        && request.resource.data.itemId is string
        && request.resource.data.itemTitle is string
        && request.resource.data.itemTitle.size() > 0
        && request.resource.data.organizerId is string
        && request.resource.data.buyerName is string
        && request.resource.data.buyerName.size() > 0
        && request.resource.data.buyerEmail is string
        && request.resource.data.recipientName is string
        && request.resource.data.recipientName.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.addressLine1 is string
        && request.resource.data.addressLine1.size() > 0
        && hasOptionalString(request.resource.data, 'addressLine2')
        && request.resource.data.city is string
        && request.resource.data.city.size() > 0
        && request.resource.data.state is string
        && request.resource.data.state.size() > 0
        && request.resource.data.postcode is string
        && request.resource.data.postcode.size() > 0
        && request.resource.data.country == 'Malaysia'
        && hasOptionalString(request.resource.data, 'deliveryInstructions')
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.status == 'confirmed'
        && request.resource.data.paymentStatus == 'notCollected'
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt == request.resource.data.createdAt
        && get(/databases/$(database)/documents/marketplaceItems/$(request.resource.data.itemId)).data.status == 'approved'
        && get(/databases/$(database)/documents/marketplaceItems/$(request.resource.data.itemId)).data.get('isAvailable', true) == true
        && get(/databases/$(database)/documents/marketplaceItems/$(request.resource.data.itemId)).data.get('quantity', 1) > 0
        && get(/databases/$(database)/documents/marketplaceItems/$(request.resource.data.itemId)).data.title == request.resource.data.itemTitle
        && get(/databases/$(database)/documents/marketplaceItems/$(request.resource.data.itemId)).data.organizerId == request.resource.data.organizerId
        && get(/databases/$(database)/documents/marketplaceItems/$(request.resource.data.itemId)).data.price == request.resource.data.price;

      allow update: if isApprovedOrganizer()
        && resource.data.organizerId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updatedAt'])
        && isMarketplaceOrderStatus(request.resource.data.status)
        && request.resource.data.updatedAt is string;

      allow delete: if false;
    }
  }
}
